local tagList = {}
local PlayerService = game:GetService("Players")
local LocalPlr = PlayerService.LocalPlayer

local function disguisePlayerUI(targetPlayer)
    local userId = PlayerService:GetUserIdFromNameAsync(targetPlayer.Name)
    local aliasName = "WrapGate_"..math.random(1, 10000)

    if targetPlayer.Name == LocalPlr.Name then
        aliasName = "WrapGate_User"
    end

    for _, uiObj in ipairs(game:GetDescendants()) do
        if uiObj:IsA("TextLabel") or uiObj:IsA("TextButton") then
            if string.find(tostring(uiObj.Text), targetPlayer.Name) then
                if not rawget(tagList, uiObj) then
                    table.insert(tagList, uiObj)
                end

                for _, conn in ipairs(getconnections(uiObj:GetPropertyChangedSignal("Text"))) do
                    conn:Disable()
                end
                for _, conn in ipairs(getconnections(uiObj.Changed)) do
                    conn:Disable()
                end
            end

            uiObj.Text = string.gsub(uiObj.Text, targetPlayer.Name, aliasName)
            uiObj:GetPropertyChangedSignal("Text"):Connect(function()
                uiObj.Text = string.gsub(uiObj.Text, targetPlayer.Name, aliasName)
            end)
        end
    end

    game.DescendantAdded:Connect(function(uiObj)
        if uiObj:IsA("TextLabel") or uiObj:IsA("TextButton") then
            if string.find(uiObj.Text, targetPlayer.Name) then
                if not rawget(tagList, uiObj) then
                    table.insert(tagList, uiObj)
                end

                for _, conn in ipairs(getconnections(uiObj:GetPropertyChangedSignal("Text"))) do
                    conn:Disable()
                end
                for _, conn in ipairs(getconnections(uiObj.Changed)) do
                    conn:Disable()
                end
            end

            uiObj:GetPropertyChangedSignal("Text"):Connect(function()
                uiObj.Text = string.gsub(uiObj.Text, targetPlayer.Name, aliasName)
            end)
        end
    end)

    local meta = getrawmetatable(game)
    local oldIndex = meta.__index
    local oldNewIndex = meta.__newindex

    if setreadonly then setreadonly(meta, false) else make_writeable(meta) end

    meta.__index = newcclosure(function(self, key)
        if not checkcaller() then
            if (key == "Text" or key == "Image") and rawget(tagList, self) then
                if key == "Text" then
                    return targetPlayer.Name
                elseif key == "Image" then
                    local updatedImg = string.gsub(string.gsub(oldIndex(self, key), userId, exploiterId), targetPlayer.Name, getgenv().ExploiterName)
                    return updatedImg
                end
            end
        end
        return oldIndex(self, key)
    end)

    meta.__newindex = newcclosure(function(self, key, val)
        if (game.IsA(self, "TextLabel") or game.IsA(self, "TextButton")) and key == "Text" and string.find(val, targetPlayer.Name) then
            if not rawget(tagList, val) then
                table.insert(tagList, val)
            end
            return oldNewIndex(self, key, string.gsub(val, targetPlayer.Name, aliasName))
        elseif (game.IsA(self, "ImageLabel") or game.IsA(self, "ImageButton")) and key == "Image" then
            if not rawget(tagList, val) then
                table.insert(tagList, val)
            end

            if string.find(val, userId) then
                return oldNewIndex(self, key, string.gsub(val, userId, getgenv().newpfp))
            elseif string.find(val, targetPlayer.Name) then
                return oldNewIndex(self, key, string.gsub(val, targetPlayer.Name, PlayerService.GetNameFromUserIdAsync(PlayerService, userId)))
            end
        end

        return oldNewIndex(self, key, val)
    end)

    if setreadonly then setreadonly(meta, true) else make_readonly(meta) end
end

for _, plr in ipairs(PlayerService:GetChildren()) do
    disguisePlayerUI(plr)
end

PlayerService.PlayerAdded:Connect(function(plr)
    disguisePlayerUI(plr)
end)
